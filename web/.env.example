# URL of the Python extraction service.
# Local: http://localhost:8000 (default if unset).
# Render: https://<your-service>.onrender.com
THREADMAP_SERVICE_URL=http://localhost:8000

# Optional. If the Render service has THREADMAP_SHARED_SECRET set, this
# Vercel proxy must send the same value or the service returns 401.
# Prevents randoms from hitting your public service URL.
THREADMAP_SHARED_SECRET=
